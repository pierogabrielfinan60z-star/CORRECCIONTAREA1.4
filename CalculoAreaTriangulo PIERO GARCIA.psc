Algoritmo CalculoAreaTriangulo
	//Calculo del área del triangulo conociendo la base y la altura
	Escribir "Calcular el área del triángulo"
	Escribir "Ingresa la base del triángulo:"
	Leer base
	
	Escribir "Ingresa la altura:"
	Leer altura
	
	//realizo el cálculo del área
	area = (base * altura) / 2
	
	//muestro el resultado
	Escribir "El área del triángulo es: " area
FinAlgoritmo
