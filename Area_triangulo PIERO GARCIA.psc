Algoritmo Area_triangulo
	Escribir "El lado a del triangulo es: "
	Leer a
	Escribir "El lado b del triangulo es: "
	Leer b
	Escribir "El lado c del triangulo es: "
	Leer c
	s= (a + b + c)/2
	are= 2/(s(s-a)(s-b)(s-c))
	Escribir "El semiperimetro es: " s
	
	Escribir "El area del triangulo es: " are
	
FinAlgoritmo
